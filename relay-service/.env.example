PORT=8787
# HOST 默认自动使用当前机器的局域网 IPv4；如需覆盖可取消注释。
# HOST=0.0.0.0

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=paseo_relay
MYSQL_SYNC=true

REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379
RELAY_INSTANCE_ID=relay-local-1
RELAY_OWNER_TTL_MS=30000
RELAY_OWNER_REFRESH_MS=10000

JWT_SECRET=your-jwt-secret-key-at-least-32-characters-long

WECHAT_APP_SECRET=your-wechat-app-secret

ALIYUN_SMS_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_SMS_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
ALIYUN_SMS_SIGN_NAME=your-sms-sign-name
ALIYUN_SMS_TEMPLATE_CODE=your-sms-template-code

# Apple In-App Purchase 配置
APPLE_IAP_SHARED_SECRET=your-apple-iap-shared-secret
APPLE_IAP_BUNDLE_ID=com.yourcompany.paseo

ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
